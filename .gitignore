# Org configuration — contains alias, instance URL; never commit
org.config

# Retrieved metadata — large, org-specific, regenerate with /retrieve
metadata/
retrieved/

# Exported org data (CPQ records, reports, dashboards, product catalog)
data/

# Analysis cache — rebuilt from metadata
cache/

# Generated output files
output/

# Org-specific analysis findings (gitignore by naming convention)
docs/bloomreach-*.md

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Salesforce CLI
.sf/
.sfdx/

# Logs
*.log
/tmp/retrieve-log.txt

# Sensitive
.env
*.pem
*.key
